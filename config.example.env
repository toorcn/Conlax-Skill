CONLAX_EMAIL_SOURCE=demo
CONLAX_USER_GOALS=AI tools,startups,hackathons,career opportunities,community building,useful professional relationships

# ClawGlasses/read-only email bridge mode
CLAWGLASSES_EMAIL_URL=
CLAWGLASSES_KEY=

# Optional enrichment and memory providers
EXA_API_KEY=
MEM0_API_KEY=

# Optional delivery settings for non-OpenClaw runners
CONLAX_TELEGRAM_TARGET=

# Optional self-test trigger.
# Send an email to the watcher mailbox with subject CONLAX_TEST.
# Body can include:
# name: Test Person
# headline: Founder at Example
# role: Founder
# company: Example
# location: Singapore
# profile_url: https://www.linkedin.com/in/example
CONLAX_SELF_TEST_ENABLED=1
CONLAX_SELF_TEST_SUBJECT=CONLAX_TEST
CONLAX_SELF_TEST_LIMIT=25
CONLAX_SELF_TEST_SKIP_NAMES=hong,tera

# Optional OpenClaw delivery for generated briefs.
# When enabled, new briefs are sent through the OpenClaw message CLI.
CONLAX_OPENCLAW_DELIVERY_ENABLED=0
CONLAX_OPENCLAW_CHANNEL=telegram
CONLAX_OPENCLAW_TARGET=
CONLAX_OPENCLAW_BIN=/Users/bing/.nvm/versions/node/v22.22.2/bin/openclaw
CONLAX_NODE_BIN_DIR=/Users/bing/.nvm/versions/node/v22.22.2/bin
